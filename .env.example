# GitHub – CodeStar/CodeConnections connection ARN (from AWS Console → Connections)
GITHUB_CONNECTION_ARN=arn:aws:codestar-connections:us-east-1:123456789012:connection/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# GitHub repo in owner/repo format (e.g. your-username/pat-cdk)
GITHUB_REPO=owner/repo

# AWS account and region (optional if using default profile; CDK often sets CDK_DEFAULT_* when you run cdk deploy)
AWS_ACCOUNT_ID=123456789012
AWS_REGION=us-east-1

# Optional: use if you need to override the account/region CDK uses
# CDK_DEFAULT_ACCOUNT=123456789012
# CDK_DEFAULT_REGION=us-east-1

# AWS credentials (only if not using AWS_PROFILE or default credentials)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# Optional: named CLI profile instead of access keys
# AWS_PROFILE=your-profile-name